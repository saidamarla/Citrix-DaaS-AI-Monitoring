# Database Configuration
DATABASE_URL=postgresql://citrix_user:citrix_password@postgres:5432/citrix_daas_db

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Collection Interval (seconds)
COLLECTION_INTERVAL_SECONDS=7200

# Ollama Configuration
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=mistral

# Citrix Cloud API Configuration
# Get these from Citrix Cloud Console: https://cloud.com
CITRIX_CLIENT_ID=your_client_id_here
CITRIX_CLIENT_SECRET=your_client_secret_here
CITRIX_CUSTOMER_ID=your_customer_id_here
CITRIX_API_URL=https://api.cloud.com

# Logging
LOG_LEVEL=INFO
